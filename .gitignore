# =============================================================================
# Plik: .gitignore
# Opis: Wzorce ignorowane przez git dla projektu iOS/Swift/Xcode.
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?

# Xcode — build i stan
build/
DerivedData/
*.xcuserstate
*.xcuserdatad/
xcuserdata/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Xcode Playgrounds
timeline.xctimeline
playground.xcworkspace

# Swift Package Manager
.build/
Packages/*/.build/
Packages/*/.swiftpm/
.swiftpm/
Package.resolved

# CocoaPods (nieużywane, ale na wszelki wypadek)
Pods/

# Carthage (nieużywane)
Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# iOS certyfikaty
*.mobileprovision
*.cer
*.p12

# Logi i pliki tymczasowe
*.log
*.tmp
*.swp
*.swo
*~

# Profile wydajności
*.trace
*.xcactivitylog
